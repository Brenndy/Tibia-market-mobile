{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/tibia/:path*", "destination": "https://api.tibiamarket.top:8001/:path*" },
    { "source": "/api/wiki/:path*", "destination": "https://tibiawiki.dev/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/" }
  ]
}
